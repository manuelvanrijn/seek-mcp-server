{
  "name": "@manuelvanrijn/seek-mcp-server",
  "version": "0.1.0",
  "description": "MCP stdio server package that exposes the seek CLI as a typed MCP tool",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "seek-mcp-server": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "clean": "rm -rf dist",
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "pretest": "npm run build",
    "test": "npm run test:integration",
    "test:integration": "node tests/integration/seek-mcp-visible-test.mjs"
  },
  "keywords": [
    "mcp",
    "seek",
    "search",
    "cli"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/manuelvanrijn/seek-mcp-server.git"
  },
  "bugs": {
    "url": "https://github.com/manuelvanrijn/seek-mcp-server/issues"
  },
  "homepage": "https://github.com/manuelvanrijn/seek-mcp-server#readme",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.6.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  }
}
